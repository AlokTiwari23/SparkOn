generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Arrays like String[] only work in PostgreSQL, which matches your schema perfectly!
}

// --- USERS & AUTH ---

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model UserCustomer {
  id           Int      @id @default(autoincrement())
  phone_number String   @unique @db.VarChar(15)
  name         String
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  cartSessions  CartSession[]
  orders        Order[]
  payments      PaymentIn[]
  reviews       Review[]
  addresses     UserAddress[]
  notifications Notification[]

  @@map("user_customers")
}

model ElectricianCustomer {
  id              Int       @id @default(autoincrement())
  phone_number    String    @unique @db.VarChar(15)
  referral_code   String    @unique @db.VarChar(10) 
  kyc_stat        KycStatus @default(PENDING)
  pan_card_number String    @default("PENDING") @db.VarChar(10)
  wallet_balance  Int       @default(0)
  bank_account    Json?     
  is_active       Boolean   @default(true)
  name            String    @db.VarChar(150)

  // Relations
  referral_orders Order[]         @relation("AttributedElectrician") // Commission earned
  personal_orders Order[]         @relation("OrderElectrician") // Personal purchase
  payoutRequests  PayoutRequest[]
  addresses       UserAddress[]
  walletLedgers   WalletLedger[]
  cartSessions    CartSession[]
  notifications   Notification[]

  @@map("electrician_customers")
}

model UserAddress {
  id             Int      @id @default(autoincrement())
  customer_id    Int?
  electrician_id Int?
  user_type      UserRole
  address_label  Label
  street_address String
  city           String   @db.VarChar(150)
  state          String   @db.VarChar(150)
  country        String   @db.VarChar(150)
  pincode        String   @db.VarChar(6)
  is_active      Boolean  @default(true)

  customer    UserCustomer?        @relation(fields: [customer_id], references: [id])
  electrician ElectricianCustomer? @relation(fields: [electrician_id], references: [id])

  orders Order[]

  @@map("user_addresses")
}

// --- PRODUCTS & INVENTORY ---

model Category {
  id        Int     @id @default(autoincrement())
  parent_id Int?
  name      String  @unique @db.VarChar(150)
  is_active Boolean @default(true)

  products Product[]

  @@map("categories")
}

model Banner {
  id       String  @id @default(uuid())
  imageUrl String  
  publicId String  

  title    String? 
  isActive Boolean @default(true)

  targetScreen String 
  targetId     String? 

  createdAt DateTime @default(now())

  @@map("banner")
}

model Product {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(150)
  description String @db.Text

  is_featured Boolean @default(false)

  // --- Packaging & Logistics ---
  uom           String @default("Piece") // "Coil", "Piece", "Box"
  master_carton Int? // Items per big shipping box

  // --- Trust & Compliance ---
  warranty      String? @db.VarChar(50) 
  is_isi_marked Boolean @default(false) 
  return_policy String? @default("7 Days")
  hsnCode  String?
  gst_tax_per Int?

  tags      String[] @default([])
  is_active Boolean  @default(true)

  // Relations
  variants   ProductVariant[]
  category   Category?        @relation(fields: [categoryId], references: [id])
  categoryId Int?
  brand      Brand?           @relation(fields: [brandId], references: [id])
  brandId    Int?

  reviews    Review[]

  @@map("products")
}

model ProductVariant {
  id             Int      @id @default(autoincrement())
  product_id     Int
  moq            Int      @default(1) // Minimum Order Qty
  is_active      Boolean  @default(true) // 🚀 ADD THIS LINE
  // --- Electrical Specific Variants ---
  sku            String   @unique @db.VarChar(50)
  color          String?  // Red, Yellow, Blue, Black, Green
  size_rating    String?  // "1.5 sq mm", "16 Amp", "9 Watt"
  images         String[] @default([])
  price_mrp      Decimal
  price_selling  Decimal
  stock_quantity Int
  boxpacking     Int      // Items per inner box
  
  product    Product     @relation(fields: [product_id], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

// --- ORDERS & PAYMENTS ---

model Order {
  id                        Int  @id @default(autoincrement())
  customer_id               Int?
  electrician_id            Int? // For personal purchase
  attributed_electrician_id Int? // For commission logic

  shipping_address_id Int 
  shipping_address    UserAddress @relation(fields: [shipping_address_id], references: [id])

  total_amount            Decimal @default(0)
  total_tax               Decimal @default(0)
  total_discount          Decimal @default(0)
  total_paid              Decimal @default(0)
  total_electrician_point Decimal @default(0)

  order_status   OrderStatus   @default(PROCESSING)
  payment_status PaymentStatus 

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  invoices   Invoice[]
  orderItems OrderItem[]
  paymentIns PaymentIn[]

  // Relations
  attributed_electrician ElectricianCustomer? @relation("AttributedElectrician", fields: [attributed_electrician_id], references: [id])
  customer               UserCustomer?        @relation(fields: [customer_id], references: [id])
  electrician            ElectricianCustomer? @relation("OrderElectrician", fields: [electrician_id], references: [id])

  @@map("orders")
}

model OrderItem {
  id                 Int     @id @default(autoincrement())
  order_id           Int
  product_variant_id Int     // 👈 FIXED: Links directly to the variant
  quantity           Int
  frozen_price       Decimal
  frozen_commission  Decimal
  subtotal           Decimal

  order           Order          @relation(fields: [order_id], references: [id])
  product_variant ProductVariant @relation(fields: [product_variant_id], references: [id]) // 👈 FIXED

  @@map("order_items")
}

model PaymentIn {
  id             Int           @id @default(autoincrement())
  order_id       Int
  customer_id    Int
  gateway_txn_id String        @db.VarChar(50)
  amount         Decimal
  method         String        @db.VarChar(50)
  status         PaymentStatus
  paid_at        DateTime      @default(now())

  customer UserCustomer @relation(fields: [customer_id], references: [id])
  order    Order        @relation(fields: [order_id], references: [id])

  @@map("payments_in")
}

model Invoice {
  id       Int    @id @default(autoincrement())
  order_id Int
  pdf_url  String

  order Order @relation(fields: [order_id], references: [id])

  @@map("invoices")
}

// --- WALLET & CART ---

model WalletLedger {
  id             Int            @id @default(autoincrement())
  electrician_id Int
  type           WalletType     @default(CREDIT)
  category       WalletCategory @default(POINT)
  amount         Decimal
  reference_id   String         @db.VarChar(20)
  description    String
  created_at     DateTime       @default(now())

  electrician ElectricianCustomer @relation(fields: [electrician_id], references: [id])

  @@map("wallet_ledgers")
}

model Brand {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100) 

  image_url       String?
  image_public_id String?

  is_active Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brands")
}

model PayoutRequest {
  id             Int          @id @default(autoincrement())
  electrician_id Int
  amount         Decimal
  status         PayoutStatus @default(REQUESTED)
  bank_utr       String?      @db.VarChar 
  processed_at   DateTime? 

  electrician ElectricianCustomer @relation(fields: [electrician_id], references: [id])

  @@map("payout_requests")
}

model CartSession {
  id                       Int      @id @default(autoincrement())
  customer_id              Int?
  electrician_id           Int?
  applied_electrician_code String?
  is_active                Boolean
  updated_at               DateTime @updatedAt

  cartItems   CartItem[]
  customer    UserCustomer?        @relation(fields: [customer_id], references: [id])
  electrician ElectricianCustomer? @relation(fields: [electrician_id], references: [id])

  @@map("cart_sessions")
}

model CartItem {
  id                 Int @id @default(autoincrement())
  cart_id            Int
  product_variant_id Int // 👈 FIXED: Links directly to the variant
  quantity           Int

  cart            CartSession    @relation(fields: [cart_id], references: [id])
  product_variant ProductVariant @relation(fields: [product_variant_id], references: [id]) // 👈 FIXED

  @@map("cart_items")
}

model Review {
  id          Int      @id @default(autoincrement())
  product_id  Int
  customer_id Int
  rating      Int      @default(5)
  comment     String?
  is_verified Boolean  @default(false)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  customer UserCustomer @relation(fields: [customer_id], references: [id])
  product  Product      @relation(fields: [product_id], references: [id])

  @@unique([product_id, customer_id])
  @@map("reviews")
}

model Notification {
  id Int @id @default(autoincrement())

  customer_id    Int?
  electrician_id Int?

  title   String @db.VarChar(100) 
  message String @db.VarChar(255) 
  type    String @default("INFO") 

  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  customer    UserCustomer?        @relation(fields: [customer_id], references: [id])
  electrician ElectricianCustomer? @relation(fields: [electrician_id], references: [id])

  @@map("notifications")
}

// --- ENUMS ---

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum UserRole {
  Electrician
  customer
  Admin
}

enum Label {
  HOME
  WORK
  SITE
  PERMANENT
}

enum WarehouseCode {
  Hata
  Kadha
  Karuriam
  Shajanaw
}

enum OrderStatus {
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  SUCCESS 
  FAILED
  REFUNDED
}

enum WalletType {
  CREDIT
  DEBIT
}

enum WalletCategory {
  POINT
  WITHDRAWAL
  REFUND_REVERSAL
  TDS_DEDUCTION
}

enum PayoutStatus {
  REQUESTED
  PROCESSED
  FAILED
}