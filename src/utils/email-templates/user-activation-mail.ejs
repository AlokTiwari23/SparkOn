<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>Email Verification</title>

  <style>
    /* RESET */
    body, table, td, a {
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
    }
    table {
      border-collapse: collapse !important;
    }
    img {
      border: 0;
      outline: none;
      text-decoration: none;
      display: block;
    }

    /* BASE */
    body {
      margin: 0;
      padding: 0;
      background-color: #f4f6f8;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
    }

    .container {
      max-width: 600px;
      margin: auto;
      background: #ffffff;
      border-radius: 14px;
      overflow: hidden;
    }

    .header {
      padding: 24px;
      text-align: center;
    }

    .title {
      font-size: 26px;
      font-weight: 700;
      color: #111827;
      margin: 0;
    }

    .content {
      padding: 24px;
      color: #374151;
      font-size: 16px;
      line-height: 24px;
    }

    .otp-wrapper {
      margin: 24px 0;
      text-align: center;
    }

    .otp {
      display: inline-block;
      padding: 16px 28px;
      font-size: 34px;
      font-weight: 700;
      letter-spacing: 6px;
      background: #f3f4f6;
      color: #111827;
      border-radius: 12px;
    }

    .warning {
      font-size: 14px;
      color: #6b7280;
    }

    .footer {
      padding: 20px;
      text-align: center;
      font-size: 12px;
      color: #9ca3af;
      background: #f9fafb;
    }

    /* DARK MODE — REAL FIX */
    @media (prefers-color-scheme: dark) {
      body {
        background-color: #0f172a !important;
      }

      .container {
        background-color: #020617 !important;
      }

      .title,
      .content,
      .otp,
      .warning {
        color: #f8fafc !important;
      }

      .content {
        color: #cbd5f5 !important;
      }

      .otp {
        background-color: #020617 !important;
        border: 1px solid #334155 !important;
      }

      .footer {
        background-color: #020617 !important;
        color: #94a3b8 !important;
      }
    }
  </style>
</head>

<body>
  <!-- PREHEADER -->
  <div style="display:none;max-height:0;overflow:hidden;">
    Your OTP is <%= otp %>. Valid for 5 minutes.
  </div>

  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding:16px;">

        <div class="container">

          <!-- LOGO -->
          <div class="header">
            <img src="https://res.cloudinary.com/dg6vd2shw/image/upload/v1768414854/svgviewer-output_7_hv9zd8.png"
                 alt="<%= companyName %>"
                 width="160">
          </div>

          <!-- CONTENT -->
          <div class="content">
            <h1 class="title">Verify your email</h1>

            <p>Hi <strong><%= userName %></strong>,</p>

            <p>
              Use the verification code below to complete your registration with
              <strong><%= companyName %></strong>.
            </p>

            <div class="otp-wrapper">
              <div class="otp"><%= otp %></div>
            </div>

            <p class="warning">
              ⏱️ This code is valid for <strong>5 minutes</strong>.  
              Never share it with anyone.
            </p>

            <p class="warning">
              If you didn’t request this, you can safely ignore this email.
            </p>

            <p>
              Regards,<br>
              <strong><%= companyName %> Team</strong>
            </p>
          </div>

          <!-- FOOTER -->
          <div class="footer">
            © <%= new Date().getFullYear() %> <%= companyName %><br>
            <a href="<%= companyUrl %>/privacy" style="color:inherit;">Privacy</a> ·
            <a href="<%= companyUrl %>/support" style="color:inherit;">Support</a>
          </div>

        </div>

      </td>
    </tr>
  </table>
</body>
</html>
